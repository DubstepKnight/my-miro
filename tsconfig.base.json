{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@my-miro/contracts": ["packages/contracts/src"],
      "@my-miro/config": ["packages/config/src"],
      "@my-miro/auth": ["packages/auth/src"]
    }
  }
}
