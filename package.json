{
  "name": "my-miro",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @my-miro/web",
    "dev:api": "npm run dev -w @my-miro/api",
    "dev:realtime": "npm run dev -w @my-miro/realtime",
    "dev:worker": "npm run dev -w @my-miro/worker",
    "docker:deps": "docker compose run --rm deps",
    "docker:migrate": "docker compose run --rm migrate",
    "docker:up:infra": "docker compose up -d db redis",
    "docker:up": "docker compose up -d",
    "docker:up:app": "docker compose up -d web api realtime worker",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "docker:logs": "docker compose logs -f",
    "docker:logs:infra": "docker compose logs -f db redis",
    "docker:logs:app": "docker compose logs -f web api realtime worker",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "typescript": "^5.6.3"
  }
}
